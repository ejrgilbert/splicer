package splicer:otel-logs@0.1.0;

/// Builtin: emit a structured `wasi:otel` log record on every wrapped
/// call. Each record carries the call's (interface, function) name as
/// attributes, severity `INFO`, an `event-name` of `"call.invoked"`,
/// an `observed-timestamp`, and trace correlation fields populated
/// from the host's `outer-span-context` when one is active. No
/// payload-derived fields — a tier-1 hook only sees the call-id.
///
/// Use a value-aware otel-logs builtin instead when you need
/// `http.method`, `error.message`, etc. on the log records.
world otel-logs-mdl {
    import wasi:otel/logs@0.2.0-rc.2;
    import wasi:otel/tracing@0.2.0-rc.2;
    import wasi:clocks/wall-clock@0.2.0;

    export splicer:tier1/after@0.2.0;
}
