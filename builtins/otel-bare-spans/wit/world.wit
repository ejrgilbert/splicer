package splicer:otel-bare-spans@0.1.0;

/// Emits one `wasi:otel` span per wrapped call: timing,
/// `code.namespace` / `code.function` attrs, and the host's outer
/// trace-id when present. No payload-derived attrs (tier-1 sees only
/// the call-id).
///
/// Value-aware sibling `splicer:otel-spans` is planned post-tier2 —
/// **not yet implemented**.
world otel-bare-spans-mdl {
    import wasi:otel/tracing@0.2.0-rc.2;
    import wasi:clocks/wall-clock@0.2.0;
    import wasi:random/random@0.2.0;

    export splicer:tier1/before@0.2.0;
    export splicer:tier1/after@0.2.0;
}
